<view class="cu-bar tabbar bg-black">
    <view class="action {{selected === 0 ? 'active' : 'default'}}" data-index="0" bindtap="switchTab">
      <view class="cuIcon-homefill"></view>
      首页
    </view>
    <view class="action {{selected === 1 ? 'active' : 'default'}}" data-index="1" bindtap="switchTab">
      <view class="cuIcon-discover"></view>
      动态
    </view>
    <view class="action {{selected === 2 ? 'active' : 'default'}} add-action" data-index="2" bindtap="switchTab">
      <button class="cu-btn cuIcon-message bg-green shadow"></button>
      消息
    </view>
    <view class="action {{selected === 3 ? 'active' : 'default'}}" data-index="3" bindtap="switchTab">
      <view class="cuIcon-cart"></view>
      购物车
    </view>
    <view class="action {{selected === 4 ? 'active' : 'default'}}" data-index="4" bindtap="switchTab">
      <view class="cuIcon-my"></view>
      我的
    </view>
</view>