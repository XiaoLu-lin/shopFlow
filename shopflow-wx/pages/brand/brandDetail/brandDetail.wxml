<cu-custom bgColor="bg-gradual-blue" isCustom="{{true}}">
  <view slot="content">店铺详情</view>
</cu-custom>

<view class="container">
  <view class="cu-card case">
    <view class="cu-item shadow" style="margin: 10rpx;">
      <view class="image">
        <image src="{{brand.picUrl}}" style="height: 300rpx;" mode="aspectFill"></image>
        <navigator class="cu-tag bg-green" wx:if="{{(status && brand.status == 0) || Administrator}}" 
        url="/pages/brand/brandAdd/brandAdd?id={{brand.id}}">编辑</navigator>
        <view class="cu-tag bg-red" wx:if="{{brand.status != 0}}">{{brand.status == 1 ? '店铺已禁用' : '店铺已注销'}}</view>
        <view class="cu-bar text-white">
          <text class="text-content">{{brand.depict}}</text>
        </view>
      </view>
      <view class="cu-list menu-avatar">
        <view class="cu-item">
          <view class="cu-avatar round lg" bindtap="openChat" style="background-image:url({{brandUser.avatarUrl}});"></view>
          <view class="content flex-sub">
            <view class="text-grey text-bold">{{brand.name}}</view>
            <view class="text-gray text-sm flex justify-between">
              联系电话：{{brandUser.mobile}}
              <view class="text-gray" >            
                <view class="fr" bindtap="showCommentModal">
                  <text class="cuIcon-messagefill"></text> {{brand.commentCount}}
                </view>
                <view class="fr margin-right text-{{brandLike ? 'red': 'grey' }}" bindtap="likeSubmit">
                  <text class="cuIcon-appreciatefill"></text> {{brand.likeCount}}
                </view>
                <view class="fr margin-right">
                  <text class="cuIcon-attentionfill"></text> {{brand.lookCount}}
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="sort">
      <view class="sort-box">
        <view class="item {{currentSortType == 'default' ? 'active' : ''}}" bindtap="openSortFilter" id="defaultSort">
          <text class="txt">综合</text>
        </view>
        <view class="item by-price {{currentSortType == 'price' ? 'active' : ''}} {{currentSortOrder == 'asc'  ? 'asc' : 'desc'}}" bindtap="openSortFilter" id="priceSort">
          <text class="txt">价格</text>
        </view>
        <view class="item {{currentSortType == 'category' ? 'active' : ''}}" bindtap="openSortFilter" id="categoryFilter">
          <text class="txt">分类</text>
        </view>
      </view>
    </view>
  </view>

  <scroll-view scroll-x class="bg-white nav" scroll-left="{{scrollLeft}}" wx-if="{{categoryFilter}}">
    <view class="flex text-center">
      <view class="cu-item" data-categoryId="{{item.id}}" wx:for="{{filterCategory}}" wx:key="id" bindtap="switchCate">
        <view class="cu-tag radius {{categoryId == item.id ?'text-orange cur':''}}">{{item.name}}</view>
      </view>
    </view>
  </scroll-view>

  <view class="box" wx:if="{{status}}" >
    <view class="cu-bar btn-group">
      <button class="cu-btn bg-green shadow-blur round" bindtap="issueGoods">发布商品</button>
      <button class="cu-btn bg-blue shadow-blur round" bindtap="getBrandOrder">销售订单</button>
    </view>
  </view>

  <block wx:if="{{status || Administrator}}">
    <goodList calss="goodList" goods="{{goodsList}}" isMyBrand="{{true}}" goodUrl="/pages/issue/issueGoods/issueGoods" 
    wx:if="{{goodsList.length != 0}}"></goodList>
    <view class="flex-sub text-center margin-top" wx:else>
      <view class="text-xsl padding">
        <text class="cuIcon-goodsnew text-grey"></text>
      </view>
      <view class="padding-0 text-grey text-bold">暂无商品</view>
    </view>
  </block>
  <block wx:else>
    <goodList calss="goodList" goods="{{goodsList}}" wx:if="{{goodsList.length != 0}}"></goodList>
    <view class="flex-sub text-center margin-top" wx:else>
      <view class="text-xsl padding">
        <text class="cuIcon-goodsnew text-grey"></text>
      </view>
      <view class="padding-0 text-grey text-bold">暂无商品</view>
    </view>
  </block>
</view>

<!-- 评论列表 -->
<commentModal id="commentModal"></commentModal>