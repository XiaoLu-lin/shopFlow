<cu-custom bgColor="bg-gradual-blue" isCustom="{{true}}">
  <view slot="content">编辑个人信息</view>
</cu-custom>

<view class="container">

  <view class="cu-list menu card-menu margin-top-xl margin-bottom-xl shadow-lg">
    <view class="cu-form-group">
      <view class="title text-bold">收件姓名</view>
      <input placeholder="收件人姓名" bindinput="bindinputName" value="{{address.name}}"></input>
    </view>
    <view class="cu-form-group">
      <view class="title text-bold">联系电话</view>
      <input placeholder="联系电话" bindinput="bindinputMobile" value="{{address.mobile}}"></input>
      <view class="cu-capsule radius">
        <view class="cu-tag bg-blue">+86</view>
        <view class="cu-tag line-blue">中国大陆</view>
      </view>
    </view>
    <!-- <view class="cu-form-group">
      <view class="title text-bold">所属区域</view>
      <input placeholder="所属区域" bindinput="bindinputName" value="{{tenant.address}}" disabled></input>
    </view> -->

    <view class="cu-form-group">
      <view class="title text-bold">区域选择</view>
      <picker mode="region" bindchange="RegionChange" value="{{region}}" custom-item="{{customItem}}">
        <view class="picker">
          {{region[0]}}，{{region[1]}}，{{region[2]}}
        </view>
      </picker>
    </view>

    <view class="cu-form-group">
      <view class="title text-bold">详细地址</view>
      <input placeholder="如几栋，几号" bindinput="bindinputAddress" value="{{address.addressDetail}}"></input>
      <text class="cuIcon-locationfill text-orange"></text>
    </view>

    <view class="cu-form-group">
      <view class="title text-bold">默认地址</view>
      <switch class="orange radius sm" bindchange="bindIsDefault" checked="{{address.isDefault}}"></switch>
    </view>
  </view>

  <view class="cu-bar btn-group add-address">
    <button class="cu-btn text-green line-green shadow"  bindtap="cancelAddress">取消</button>
    <button class="cu-btn bg-green shadow-blur" bindtap="saveAddress">保存</button>
  </view>

</view>
