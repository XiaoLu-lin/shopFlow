<cu-custom bgColor="bg-gradual-blue" isCustom="{{true}}">
  <view slot="content">消息列表</view>
</cu-custom>

<view class="container">
  <view class="cu-bar bg-white solid-bottom">
    <view class="action">
      <text class="cuIcon-title text-orange"></text> 消息列表
    </view>
    <button class="cu-btn fr bg-green margin-right-sm" bindtap="messageSubscribe">订阅新消息通知</button>
  </view>

  <view class="no-login" wx:if="{{!hasLogin}}">
    <view class="cu-list menu card-menu margin-top-half margin-bottom-xl shadow-lg" 
    style="margin-left: 10rpx;margin-right: 10rpx;">
      <view class="cu-item" style='min-height: 200rpx;'>
        <view wx:if="{{!hasLogin}}" class="content grid col-1">
          <view class="padding-sm text-sm flex justify-center">
            <text class="text-grey">允许微信授权后，可体验更多功能</text>
          </view>
          <view class="padding-sm flex justify-center">
            <button bindtap="goLogin" class='cu-btn round bg-green shadow'>授权登陆</button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <block wx:else>
    <view class="cu-list menu-avatar bg-white">
      <view class="cu-item solid-bottom {{modalName=='move-box-'+ index?'move-cur':''}}" wx:for="{{messageList}}" wx:key bindtouchstart="ListTouchStart" bindtouchmove="ListTouchMove" bindtouchend="ListTouchEnd" 
      data-target="move-box-{{index}}">
        <view class="cu-avatar radius-sm lg" style="background-image:url({{item.avatarUrl}});" 
        bindtap="openChat" data-index="{{index}}"></view>
        <view class="content" bindtap="openChat" data-index="{{index}}">
          <view class="text-grey">
            <view class="text-cut text-bold" style="width: 85%;">{{item.nickName}}</view>
          </view>
          <view class="text-gray text-sm flex">
            <view class="text-cut" style="width: 85%;">{{item.content}}</view>
          </view>
        </view>
        <view class="action" style="width: 130rpx;">
          <view class="text-grey text-sm">{{item.addTime}}</view>
        </view>
        <view class="move">
          <view class="bg-red" bindtap="deleteMessage" data-index="{{index}}">删除</view>
        </view>
      </view>
    </view>

    <view wx:if="{{messageList.length <= 0}}">
      <view class="flex-sub text-center margin-top-half">
        <view class="text-xsl padding">
          <text class="cuIcon-wefill text-grey"></text>
        </view>
        <view class="padding-0 text-grey text-bold">暂无消息</view>
      </view>
    </view>
  </block>
  
  <view class='cu-tabbar-height'></view>
</view>
