<cu-custom bgColor="bg-gradual-blue" isCustom="{{true}}">
  <view slot="content">搜索</view>
</cu-custom>

<view class="search-header">
  <view class="cu-bar search bg-white">
    <view class="search-form round">
      <text class="cuIcon-search"></text>
      <input name="input" focus="true" data-value="{{keyword}}" value="{{keyword}}" confirm-type="search" bindinput="inputChange" bindfocus="inputFocus" bindconfirm="onKeywordConfirm" placeholder="{{defaultKeyword.keyword}}" />
      <text class="cuIcon-roundclose" style="margin-right: 30rpx;" wx:if="{{keyword}}" bindtap="clearKeyword"></text>
    </view>
    <view class="action">
      <button class="cu-btn bg-green shadow-blur round" data-value="{{keyword}}" bindtap="onKeywordConfirm">搜索</button>
    </view>
  </view>
  <view class="search-result" wx:if="{{ searchStatus && goodsList.length}}">
    <view class="sort">
      <view class="sort">
        <view class="sort-box">
          <view class="item {{currentSortType == 'default' ? 'active' : ''}}" bindtap="openSortFilter" id="defaultSort">
            <text class="txt">综合</text>
          </view>
          <view class="item by-price {{currentSortType == 'price' ? 'active' : ''}} {{currentSortOrder == 'asc'  ? 'asc' : 'desc'}}" bindtap="openSortFilter" id="priceSort">
            <text class="txt">价格</text>
          </view>
          <view class="item {{currentSortType == 'category' ? 'active' : ''}}" bindtap="openSortFilter" id="categoryFilter">
            <text class="txt">分类</text>
          </view>
        </view>
      </view>
    </view>
    <scroll-view scroll-x class="bg-white nav" scroll-left="{{scrollLeft}}" wx-if="{{categoryFilter}}">
      <view class="flex text-center">
        <view class="cu-item" data-categoryId="{{item.id}}" wx:for="{{filterCategory}}" wx:key="id" bindtap="switchCate">
          <view class="cu-tag radius {{categoryId == item.id ?'text-orange cur':''}}">{{item.name}}</view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>

<view class="container">
  <view class="no-search" wx:if="{{!searchStatus}}">
    <view class="cu-list menu card-menu margin-xs shadow-lg" wx:if="{{!keyword && historyKeyword.length}}">
      <view class="cu-item" >
        <view class="content">
          <view class="cu-bar bg-white tabbar border shop">
            <text class="text-grey text-bold">搜索历史</text>
            <text class="cuIcon-deletefill text-grey" bindtap="clearHistory">删除</text>
          </view>
          <view class="search-keywords search-history">
            <view class="b">
              <view class="item" bindtap="onKeywordTap" data-keyword="{{item.keyword}}" wx:for="{{historyKeyword}}" wx:key="keyword" hover-class="navigator-hover">{{item.keyword}}</view>
            </view>
          </view>
				</view>
      </view>
    </view>

    <view class="cu-list menu card-menu margin-xs shadow-lg" wx:if="{{!keyword && hotKeyword.length}}">
      <view class="cu-item" >
        <view class="content">
          <view class="cu-bar bg-white tabbar border shop">
            <text class="text-grey text-bold">热门搜索</text>
          </view>
          <view class="search-keywords search-history">
            <view class="b">
              <view class="item {{item.is_hot === 1 ? 'active' : ''}}" hover-class="navigator-hover" bindtap="onKeywordTap" data-keyword="{{item.keyword}}" wx:for="{{hotKeyword}}" wx:key="id">{{item.keyword}}</view>
            </view>
          </view>
          <view class="shelper-list" wx:if="{{keyword}}">
            <view class="item" hover-class="navigator-hover" wx:for="{{helpKeyword}}" wx:key="id" bindtap="onKeywordTap" data-keyword="{{item}}">{{item}}</view>
          </view>
				</view>
      </view>
    </view>

    <view class="cu-list menu radius-sm margin-xs shadow-lg" wx:if="{{keyword}}">
      <view class="cu-item arrow" wx:for="{{helpKeyword}}" wx:key="id">
        <view class="content" bindtap="onKeywordTap" data-keyword="{{item}}">
          {{item}}
				</view>
      </view>
    </view>

    <view class="search-result-empty" wx:if="{{!hotKeyword.length && !historyKeyword.length}}">
      <view class="flex-sub text-center margin-top-half">
        <view class="text-xsl padding">
          <text class="cuIcon-search text-grey"></text>
        </view>
        <view class="text-grey text-bold">商品搜索</view>
      </view>
    </view>
  </view>

  <view class="search-result" wx:if="{{ searchStatus && goodsList.length}}">
    <view class="cate-item">
      <goodList calss="goodList" goods="{{goodsList}}"></goodList>
    </view>
  </view>

  <view class="search-result-empty" wx:if="{{!goodsList.length && searchStatus}}">
    <view class="flex-sub text-center margin-top-half">
      <view class="text-xsl padding">
        <text class="cuIcon-same text-grey"></text>
      </view>
      <view class="text-grey text-bold">您寻找的商品还未上架</view>
    </view>
  </view>
</view>