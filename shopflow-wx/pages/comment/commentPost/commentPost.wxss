page, .container {
  height: 100%;
  background: #f4f4f4;
}

.comment-textarea{
  width: 100%;
  height: 400rpx;
  border-radius: 10rpx;
  border: 5px solid #f4f4f4;
  background-color: #f4f4f4;
}

.comment-post {
  background: #fff;
  overflow: hidden;
  position: fixed;
  left: 0;
  bottom: 0;
  float: right;
  height: 100rpx;
  width: 97%;
}
