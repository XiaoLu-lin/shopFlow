/* lib/components/commentModal/commentModal.wxss */
@import "/lib/colorui/icon.wxss";
@import "/lib/colorui/main.wxss";


.cart-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #fff;
  z-index: 1024;
}


.comment-reply{
  width: 450rpx;
  border: 5px solid #f4f4f4;
  border-top-left-radius: 10rpx;
  border-top-right-radius: 10rpx;
  background-color: #f4f4f4;
  margin-top: 20rpx;
}

.comment-textarea {
  width: 450rpx;
  border-bottom-right-radius: 10rpx;
  border-bottom-left-radius: 10rpx;
  border: 5px solid #f4f4f4;
  background-color: #f4f4f4;
  margin-bottom: 20rpx;
}

.comment-textarea .reply {
  width: 450rpx;
  border-radius: 10rpx;
  border: 5px solid #f4f4f4;
  background-color: #f4f4f4;
  margin-bottom: 20rpx;
}