<cu-custom bgColor="bg-gradual-blue" isCustom="{{true}}">
  <view slot="content">帮助中心</view>
</cu-custom>
<view class="container">

 <!-- 常见问题 -->
 <view class="cu-list menu card-menu margin-xs shadow-lg" style="margin: 10rpx;">
    <view class="cu-item">
			<view class="common-problem">
        <view class="h">
          <view class="line"></view>
          <text class="title text-bold">常见问题</text>
        </view>
        <view class="b">
          <view class="item" wx:for="{{issueList}}" wx:key="id">
            <view class="question-box">
              <text class="spot"></text>
              <text class="question text-bold">{{item.question}}</text>
            </view>
            <view class="answer">
              {{item.answer}}
            </view>
          </view>
        </view>
      </view>
		</view>
  </view> 

  <view style="height: 150rpx;"></view>

  <view class="cu-list menu card-menu shadow-lg cu-bar foot" style="width: 97%;margin: 10rpx;background-color: #ffff;">
    <view class="cu-item" style="background-color: #ffff">
      <view class="page" wx:if="{{showPage}}">
        <view class="prev {{ page <= 1 ? 'disabled' : ''}}" bindtap="prevPage">上一页</view>
        <view class="next {{ (count / size) <= page ? 'disabled' : ''}}" bindtap="nextPage">下一页</view>
      </view>
    </view>
  </view>
</view>