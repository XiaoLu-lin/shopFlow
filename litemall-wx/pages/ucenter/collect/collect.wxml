<cu-custom bgColor="bg-gradual-blue" isCustom="{{true}}">
  <view slot="content">我的收藏</view>
</cu-custom>

<view class="container">
  <view class="collect-switch">
    <view class="item {{ type == 0 ? 'active' : ''}}" bindtap="switchTab" data-index='0'>
      <view class="txt text-bold">商品收藏</view>
    </view>
    <view class="item {{ type == 1 ? 'active' : ''}}" bindtap="switchTab" data-index='1'>
      <view class="txt text-bold">专题收藏</view>
    </view>
  </view>
  <view class="no-collect" wx:if="{{collectList.length <= 0}}">
    <view class="flex-sub text-center margin-top-half">
      <view class="text-xsl padding">
        <text class="cuIcon-wefill text-grey"></text>
      </view>
      <view class="padding-0 text-grey text-bold">还没有收藏</view>
    </view>
  </view>
  <block wx:else>
    <block wx:if="{{type == 0}}">
      <view  class="cu-list menu card-menu shadow-lg margin-top-sm" style="margin: 10rpx;" >
        <view class="cu-item" style="padding: 20rpx;" wx:for="{{collectList}}" wx:key="id">
          <view class="content flex align-center" 
          bindtap="openCollect" bindtouchstart="touchStart" bindtouchend="touchEnd" data-index="{{index}}">
            <view class="margin-right">
              <view class="cu-avatar xxl radius-sm" style="background-image:url({{item.picUrl}});"></view>
            </view>
            <view class="bg-white">
              <view class="title">
                <view class="text-cut text-bold">{{item.name}}</view>
              </view>
              <view class="text-content text-grey text-df">{{item.brief}}</view>
              <view class="cu-tag radius bg-red">￥{{item.price}}</view>
            </view>
          </view>
        </view>
      </view>
    </block>
    <block wx:if="{{type == 1}}">
      <view class="cu-card article" wx:for="{{collectList}}" wx:key="id">
        <navigator class="cu-item shadow" style="margin: 10rpx;" 
        bindtap="openCollect" bindtouchstart="touchStart" bindtouchend="touchEnd" data-index="{{index}}">
          <view class="title">
            <view class="text-cut">{{item.name}}</view>
          </view>
          <view class="content">
            <image src="{{item.picUrl}}" mode="aspectFill"></image>
            <view class="desc">
              <view class="text-content">{{item.brief}}</view>
              <view>
                <view class="cu-tag bg-red light sm radius">{{item.price}}元起</view>
              </view>
            </view>
          </view>
        </navigator>
      </view>
    </block>
  </block>
</view>