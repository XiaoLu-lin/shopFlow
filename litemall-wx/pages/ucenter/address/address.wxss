page{
  height: 750rpx;
  width: 100%;
}

.container{
  height: 750rpx;
  width: 100%;
}

.address-list {
  width: 100%;
  height: 166.55rpx;
  background-size: 62.5rpx 10.5rpx;
  margin-bottom: 10rpx;
  padding-top: 10.5rpx;
}

.address-list .item {
  display: flex;
  height: 155.55rpx;
  background: #fff;
  width: 100%;
  padding: 25rpx 0rpx;
}

.address-list .l {
  height: 100%;
}

.address-list .l .name {
  margin-left: 6.25rpx;
  margin-top: 19rpx;
  display: block;
  line-height: 43rpx;
  font-size: 38rpx;
  margin-bottom: 13rpx;
}

.address-list .l .default {
  margin-left: 6.25rpx;
  display: block;
  width: 62rpx;
  height: 33rpx;
  border-radius: 5rpx;
  border: 1px solid #b4282d;
  font-size: 20.5rpx;
  text-align: center;
  line-height: 29rpx;
  color: #b4282d;
}

.address-list .m {
  flex: 1;
  margin-left: 34rpx;
}

.address-list .mobile {
  display: block;
  margin-top: 17.75rpx;
  font-size: 38rpx;
}

.address-list .address {
  display: block;
  font-size: 27rpx;
}

.address-list .r {
  display: flex;
  justify-content: center;
  align-items: center;
}

.address-list .r image {
  width: 52.078rpx;
  height: 52.078rpx;
}

.add-address {
  right: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 80%;
  height: 90rpx;
  line-height: 98rpx;
  position: absolute;
  bottom: 0;
  left: 0;
  border-radius: 0;
  padding: 0;
  margin: 0;
  margin-left: 10%;
  text-align: center;
  margin-bottom: 20rpx;
  font-size: 35rpx;
  color: #ffffff;
  border-top-left-radius: 50rpx;
  border-bottom-left-radius: 50rpx;
  border-top-right-radius: 50rpx;
  border-bottom-right-radius: 50rpx;
  letter-spacing: 3rpx;
  background: #39b54a;
}

.empty-view {
  height: 100%;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-view .icon {
  height: 248rpx;
  width: 258rpx;
  margin-bottom: 10rpx;
}

.empty-view .text {
  width: auto;
  font-size: 28rpx;
  line-height: 35rpx;
  color: #999;
}
