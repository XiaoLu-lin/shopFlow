<cu-custom bgColor="bg-gradual-blue" isCustom="{{true}}">
  <view slot="content">我的足迹</view>
</cu-custom>

<view class="container">
  <view class="no-footprint" wx:if="{{footprintList.length <= 0}}">
    <view class="flex-sub text-center margin-top-half">
      <view class="text-xsl padding">
        <text class="cuIcon-wefill text-grey"></text>
      </view>
      <view class="padding-0 text-grey text-bold">没有浏览足迹</view>
    </view>
  </view>
  <view class="footprint" wx:if="{{footprintList.length > 0}}">
    <view class="day-item" wx:for="{{footprintList}}" wx:key="*this" wx:for-index="index">
      <view class="day-hd" wx:if="{{item.length > 0}}">{{item[0].addDate}}</view>
      <view class="day-list" wx:if="{{item.length > 0}}">
        <view  class="cu-list menu card-menu shadow-lg margin-top-sm" style="margin: 10rpx;" >
          <view class="cu-item" style="padding: 20rpx;" wx:for="{{item}}" wx:for-index="iindex" wx:for-item="iitem">
            <view class="content flex align-center" data-index="{{index}}" data-iindex="{{iindex}}" bindtouchstart="touchStart" bindtouchend="touchEnd" bindtap="deleteItem">
              <view class="margin-right">
                <view class="cu-avatar xxl radius-sm" style="background-image:url({{iitem.picUrl}});"></view>
              </view>
              <view class="bg-white" style="width: 100%;">
                <view class="title">
                  <view class="text-cut text-bold">{{iitem.name}}</view>
                </view>
                <view class="text-content text-grey text-df">{{iitem.brief}}</view>
                <view class="flex justify-between" style="margin-top: 10rpx;">
                  <view class="cu-capsule radius">
                    <view class="cu-tag bg-red sm">￥</view>
                    <view class="cu-tag line-red sm">{{iitem.retailPrice}}</view>
                  </view>
                  <view class="cu-capsule radius">
                    <view class="cu-tag bg-green sm">浏览次数</view>
                    <view class="cu-tag line-green sm">x{{iitem.version + 1}}</view>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>