/* pages/ucenter/withdraw/withdraw.wxss */

page, .container {
  height: 100%;
  background: #f4f4f4;
}

.comment-textarea{
  padding-top: 20rpx;
  height: 100rpx;
  width: 100%;
  border-radius: 10rpx;
  align-items: center;
  border: 5px solid #f4f4f4;
  background-color: #f4f4f4;
}

.comment-post {
  background: #fff;
  overflow: hidden;
  position: fixed;
  left: 0;
  bottom: 0;
  float: right;
  height: 50rpx;
  width: 97%;
}
