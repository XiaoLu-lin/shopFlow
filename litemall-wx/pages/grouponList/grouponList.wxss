.container{
  width: 100%;
  height: 100%;
}

 .nav-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-left: 10rpx;
  margin-right: 10rpx;
}

.nav-li {
  border-radius: 12rpx;
  width: 49%;
  background-image: url(https://image.weilanwl.com/color2.0/cardBg.png);
  background-size: cover;
  background-position: center;
  position: relative;
  z-index: 1;
  margin-top: 10rpx;
  margin-bottom: 10rpx;
}

.nav-li::after {
  content: "";
  position: absolute;
  z-index: -1;
  background-color: inherit;
  width: 100%;
  height: 100%;
  left: 0;
  bottom: -10%;
  border-radius: 10rpx;
  opacity: 0.2;
  transform: scale(0.9, 0.9);
}