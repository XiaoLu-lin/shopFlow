<cu-custom bgColor="bg-gradual-blue" isCustom="{{true}}">
  <view slot="content">账号登陆</view>
</cu-custom>

<view class="img-a" >
  <view class="t-b">
    您好，管理员
  </view>
</view>
<view class="container" >
	<view class="cu-list menu card-menu shadow-lg" style="margin: 0rpx;margin-top: -200rpx;border-radius: 50rpx;">
		<view class="cu-item" style="padding: 50rpx 60rpx 0rpx 60rpx;">
			<view class="content">
        <view class="text-bold margin-top">账号</view>
				<view class="form-item">
					<input class="username" value="{{username}}" bindinput="bindUsernameInput" placeholder="请输入账号"/>
          <text class="cuIcon-roundclosefill lg text-gray clear" id="clear-username" wx:if="{{ username.length > 0 }}" name="close" catchtap="clearInput"></text>   
				</view>
			</view>
		</view>
		<view class="cu-item" style="padding: 0rpx 60rpx 0rpx 60rpx;">
			<view class="content">
        <view class="text-bold margin-top">密码</view>
				<view class="form-item">
					<input class="password" value="{{password}}" password bindinput="bindPasswordInput" placeholder="请输入密码"/>
          <text class="cuIcon-roundclosefill lg text-gray clear" id="clear-password" wx:if="{{ password.length > 0 }}" name="close" catchtap="clearInput"></text>   
				</view>
			</view>
		</view>
		<view class="cu-item" style="padding: 0rpx 60rpx 0rpx 60rpx;">
			<view class="form-item-code">
        <view class="text-bold margin-top">验证码</view>
				<view class="form-item code-item">
					<input class="code" value="{{code}}" bindinput="bindCodeInput" placeholder="请输入验证码" />
					<text class="cuIcon-roundclosefill lg text-gray clear" id="clear-code" wx:if="{{ code.length > 0 }}" 
          name="close" catchtap="clearInput"></text>   
				</view>
        <button class="cu-btn bg-green shadow-blur fr margin-top-sm" bindtap="sendCode">获取验证码</button>
			</view>
		</view>
		<view class="cu-item">
			<view class="content">
			<button type="primary" class="login-btn" open-type="getPhoneNumber" bindgetphonenumber="bindPhoneNumber">管理员登陆</button>
			</view>
		</view>
    <!-- <view class="cu-item">
      <navigator url="/pages/auth/register/register" class="register">注册账号</navigator>
			<navigator url="/pages/auth/reset/reset" class="reset">忘记密码</navigator>
		</view> -->
	</view>
</view>