<cu-custom bgColor="bg-gradual-blue" isCustom="{{true}}">
  <view slot="content">登陆</view>
</cu-custom>
<view class="container">
  <view class="cu-list menu card-menu margin-top-xl margin-bottom-xl shadow-lg flex">
		<view class="cu-item user_row">
			<view class="content user_row_left">
				<text class="text-grey">登录</text>
			</view>
		</view>
		<view class="cu-item">
			<view class="content">
				<button type="primary" class="wx-login-btn" open-type="getPhoneNumber" 
        bindgetphonenumber="bindPhoneNumber">手机号登陆</button>
			</view>
		</view>
		<view class="cu-item">
			<view class="content">
				<button type="primary" class="account-login-btn" bindtap="accountLogin">管理员登录</button>
			</view>
		</view>
	</view>
</view>