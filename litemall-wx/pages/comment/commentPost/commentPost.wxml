<cu-custom bgColor="bg-gradual-blue" isCustom="{{true}}">
  <view slot="content">商品评价</view>
</cu-custom>

<view class="container">
  <view class="cu-list menu card-menu shadow-lg" style="margin: 10rpx;">
    <view class="cu-item">
      <view class="content">
        <text class="text-grey text-bold">商品信息</text>
      </view>
    </view>

    <!--商品详情-->
    <goodsItem goods="{{orderGoods}}"></goodsItem>

  </view>

  <view class="cu-list menu card-menu shadow-lg" style="margin: 10rpx;">
    <view class="cu-item">
      <view class="content">
        <text class="rater-title">评分</text>
        <block wx:for="{{stars}}" wx:key="*this" wx:for-item="item">
          <text class="cuIcon-likefill text-red" bindtap="selectRater" data-star="{{item}}" wx:if="{{item < star}}"></text>
          <text class="cuIcon-like text-red" bindtap="selectRater" data-star="{{item}}" wx:else></text>
        </block>
        <text class="rater-desc">{{starText}}</text>
      </view>
    </view>
  </view>

  <view class="cu-list menu card-menu shadow-lg" style="margin: 10rpx;">
    <view class="cu-bar bg-white">
      <view class="action text-grey text-bold">
        商品留言
      </view>
      <view class="action text-grey text-bold">
        {{content.length}}/100
      </view>
    </view>
    <view class="cu-item">
      <view class="content">
        <textarea class="comment-textarea" focus="true" bindinput="bindInputValue" 
        maxlength="500" placeholder="留言经过筛选后，对所有人可见"></textarea>
      </view>
    </view>

    <uploadImg imgSite="4" title="图片上传" bind:getImage="getContentImage"></uploadImg>
  </view>

  <view style="padding-bottom: 140rpx;"></view>

  <view class="cu-list menu card-menu margin-xs shadow-lg comment-post" style="margin: 10rpx;">
    <view class="cu-item" style="background-color: #ffff">
      <view class="content">
          <view class="flex solid-bottom justify-end fr">
            <button class="cu-btn margin-left bg-red" bindtap="onClose">取消</button>   
            <button class="cu-btn margin-left bg-green" bindtap="onPost">发表</button>  
          </view>
      </view>
    </view>
  </view>
</view>