<cu-custom bgColor="bg-gradual-blue" isCustom="{{true}}">
  <view slot="content">销售订单</view>
</cu-custom>

<scroll-view scroll-x class="bg-white nav orders-switch">
  <view class="flex text-center">
    <view class="cu-item flex-sub {{index==showType?'text-orange cur':''}}" wx:for="{{tableName}}" 
    wx:key='id' bindtap="switchTab" data-index="{{index}}">
      <text class="text-bold">{{tableName[index]}}</text>
    </view>
  </view>
</scroll-view>

<view class="container">
  <view class="cu-bar search bg-white" wx:if="{{showType == 0}}">
    <view class="search-form round">
      <text class="cuIcon-search"></text>
      <input type="text" placeholder="请输入电话号码" value="{{mobile}}" confirm-type="search" bindinput="bindExchange"></input>
      <text class="cuIcon-roundclose" style="margin-right: 30rpx;" wx:if="{{mobile.length > 0}}" bindtap="clearExchange"></text>
    </view>
    <view class="action">
      <button class="cu-btn bg-green shadow-blur round" bindtap='goSearch'>搜索</button>
    </view>
  </view>

  <block wx:if="{{orderVoList.length > 0}}">
    <view  class="cu-list menu card-menu shadow-lg" style="margin: 10rpx;" wx:for="{{orderVoList}}"  wx:key="id">
      <view class="cu-item" >
        <view class="content">
          <text class="text-grey text-bold">地址：{{item.address}}</text>
          <text class="text-red text-bold fr">{{item.orderStatusText}}</text>
        </view>
      </view>

      <!--商品详情-->
      <goodsItem goods="{{item.goods}}" bindtap="showOrder" data-ordervo="{{item}}"></goodsItem>

      <view class="cu-item">
        <view class="content">
          <text class="text-red text-bold">合计实付：￥{{item.actualPrice}}元</text>
          <block  wx:if="{{item.aftersaleStatus == 0}}">
            <button class="cu-btn bg-green fr margin-left-xs" bindtap="showModal" 
            data-index="{{index}}" data-target="wxShip" wx:if="{{item.ship}}">发货</button>
            <button class="cu-btn bg-grey fr margin-left-xs" bindtap="wxCancel" 
            data-index="{{index}}" wx:if="{{item.ship}}">取消</button>

            <button class="cu-btn bg-red fr margin-left-xs" bindtap="wxRefund" 
            data-index="{{index}}" wx:if="{{item.refund}}">退款</button>
          </block>
          <block wx:if="{{item.aftersaleStatus == 1}}">
            <button class="cu-btn bg-green fr margin-left-xs" bindtap="wxAftersaleRecept" 
            data-index="{{index}}">通过</button>
            <button class="cu-btn bg-red fr margin-left-xs" bindtap="wxAftersaleReject" 
            data-index="{{index}}">拒绝</button>
          </block>
          <block wx:if="{{item.aftersaleStatus == 2}}">
            <button class="cu-btn bg-red fr margin-left-xs" bindtap="wxAftersaleRefund" 
            data-index="{{index}}">退款</button>
          </block>
        </view>
      </view>
    </view>
  </block>

  <view wx:if="{{orderVoList.length <= 0}}">
    <view class="flex-sub text-center margin-top-half">
      <view class="text-xsl padding">
        <text class="cuIcon-discover text-grey"></text>
      </view>
      <view class="padding-0 text-bold text-grey">还没有订单</view>
    </view>
  </view>

</view>


<view class="cu-modal {{modalName=='wxShip'?'show':''}}">
  <view class="cu-dialog">
    <view class="cu-bar bg-white justify-end">
      <view class="content text-bold">发货信息</view>
      <view class="action" bindtap="hideModal">
        <text class="cuIcon-close text-red"></text>
      </view>
    </view>
    <form bindsubmit='wxShip'>
      <view class="cu-form-group">
        <view class="title text-bold">发货编号：</view>
        <input placeholder="必填" name="shipSn"></input>
      </view>
      <view class="cu-form-group">
        <view class="title text-bold">发货方式：</view>
        <picker value="{{index}}" range-key="name" bindchange="bindPickerChange" range="{{channel}}">
          <view class="picker">
            {{channel[index].name}}
          </view>
        </picker>
      </view>
      <view class="cu-bar bg-white">
        <button class="cu-btn line-green text-green flex-sub margin-sm" style="height: 80rpx;" bindtap="hideModal">取消</button>
        <button class="cu-btn bg-green flex-sub margin-sm" style="height: 80rpx;" data-shipChannel="{{channel[index].code}}" 
        form-type='submit'>确定</button>
      </view>
    </form>
  </view>
</view>