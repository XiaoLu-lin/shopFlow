  
.container {
  min-height: 100%;
  margin-bottom: 200rpx;
}

.comment-textarea{
  width: 100%;
  height: 400rpx;
  border-radius: 10rpx;
  border: 5px solid #f4f4f4;
  background-color: #f4f4f4;
}

.add-button {
  position: fixed;
  bottom: 0;
  left: 0;
  display: flex;
  right: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 80%;
  height: 90rpx;
  line-height: 98rpx;
  position: absolute;
  bottom: 0;
  left: 0;
  border-radius: 0;
  padding: 0;
  margin: 0;
  margin-left: 10%;
  text-align: center;
  margin-bottom: 30rpx;
  font-size: 35rpx;
  color: #ffffff;
  border-top-left-radius: 50rpx;
  border-bottom-left-radius: 50rpx;
  border-top-right-radius: 50rpx;
  border-bottom-right-radius: 50rpx;
  letter-spacing: 3rpx;
  background: #39b54a;
}