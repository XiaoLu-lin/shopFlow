<cu-custom bgColor="bg-gradual-blue" isCustom="{{true}}">
  <view slot="content">人气推荐</view>
</cu-custom>

<view class="container">
  <view class="cu-list menu card-menu shadow-lg" style="margin: 10rpx;">
    <view class="brand-info">
      <view class="name">
        <image class="img" src="{{bannerInfo.imgUrl}}" background-size="cover"></image>
        <view class="info-box">
          <view class="info">
            <text class="txt">{{bannerInfo.name}}</text>
            <text class="line"></text>
          </view>
        </view>
      </view>
    </view>
    <view class="sort">
      <view class="sort-box">
        <view class="item {{currentSortType == 'default' ? 'active' : ''}}" bindtap="openSortFilter" id="defaultSort">
          <text class="txt">综合</text>
        </view>
        <view class="item by-price {{currentSortType == 'price' ? 'active' : ''}} {{currentSortOrder == 'asc'  ? 'asc' : 'desc'}}" bindtap="openSortFilter" id="priceSort">
          <text class="txt">价格</text>
        </view>
        <view class="item {{currentSortType == 'category' ? 'active' : ''}}" bindtap="openSortFilter" id="categoryFilter">
          <text class="txt">分类</text>
        </view>
      </view>
    </view>
  </view>

  <scroll-view scroll-x class="bg-white nav" scroll-left="{{scrollLeft}}" wx-if="{{categoryFilter}}">
    <view class="flex text-center">
      <view class="cu-item" data-categoryId="{{item.id}}" wx:for="{{filterCategory}}" wx:key="id" bindtap="switchCate">
        <view class="cu-tag radius {{categoryId == item.id ?'text-orange cur':''}}">{{item.name}}</view>
      </view>
    </view>
  </scroll-view>

  <goodList calss="goodList" goods="{{goodsList}}"></goodList>

</view>