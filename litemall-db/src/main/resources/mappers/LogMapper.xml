<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.ysling.litemall.db.mapper.LogMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="org.ysling.litemall.db.domain.LitemallLog">
        <id column="id" property="id" />
        <result column="admin" property="admin" />
        <result column="ip" property="ip" />
        <result column="type" property="type" />
        <result column="action" property="action" />
        <result column="status" property="status" />
        <result column="result" property="result" />
        <result column="comment" property="comment" />
        <result column="add_time" property="addTime" />
        <result column="update_time" property="updateTime" />
        <result column="deleted" property="deleted" />
        <result column="tenant_id" property="tenantId" />
        <result column="version" property="version" />
    </resultMap>


    <!-- 真实删除 -->
    <delete id="actualDeleteById">
        DELETE FROM litemall_log WHERE id = #{id}
    </delete>

    <!-- 批量真实删除 -->
    <delete id="actualDeleteByIds">
        DELETE FROM litemall_log WHERE id IN (
            SELECT id FROM (
                SELECT DISTINCT id
                FROM litemall_log
                WHERE id IN
                <foreach item="id" collection="idList" open="(" separator="," close=")">
                    #{id}
                </foreach>
            ) AS tmp
        )
    </delete>


</mapper>
