<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.ysling.shopflow.db.mapper.DealingSlipMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="org.ysling.shopflow.db.domain.ShopflowDealingSlip">
        <id column="id" property="id" />
        <result column="user_id" property="userId" />
        <result column="openid" property="openid" />
        <result column="order_sn" property="orderSn" />
        <result column="award" property="award" />
        <result column="balance" property="balance" />
        <result column="deal_type" property="dealType" />
        <result column="remark" property="remark" />
        <result column="status" property="status" />
        <result column="last_deal_ip" property="lastDealIp" />
        <result column="out_batch_no" property="outBatchNo" />
        <result column="batch_id" property="batchId" />
        <result column="batch_time" property="batchTime" />
        <result column="add_time" property="addTime" />
        <result column="update_time" property="updateTime" />
        <result column="deleted" property="deleted" />
        <result column="tenant_id" property="tenantId" />
        <result column="version" property="version" />
    </resultMap>


    <!-- 真实删除 -->
    <delete id="actualDeleteById">
        DELETE FROM shopflow_dealing_slip WHERE id = #{id}
    </delete>

    <!-- 批量真实删除 -->
    <delete id="actualDeleteByIds">
        DELETE FROM shopflow_dealing_slip WHERE id IN (
            SELECT id FROM (
                SELECT DISTINCT id
                FROM shopflow_dealing_slip
                WHERE id IN
                <foreach item="id" collection="idList" open="(" separator="," close=")">
                    #{id}
                </foreach>
            ) AS tmp
        )
    </delete>


</mapper>
