<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.ysling.shopflow.db.mapper.MessageMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="org.ysling.shopflow.db.domain.ShopflowMessage">
        <id column="id" property="id" />
        <result column="avatar_url" property="avatarUrl" />
        <result column="nick_name" property="nickName" />
        <result column="send_user_id" property="sendUserId" />
        <result column="receive_user_id" property="receiveUserId" />
        <result column="content" property="content" />
        <result column="pic_urls" property="picUrls" typeHandler="org.ysling.shopflow.db.handler.JsonStringArrayTypeHandler"/>
        <result column="add_time" property="addTime" />
        <result column="update_time" property="updateTime" />
        <result column="deleted" property="deleted" />
        <result column="tenant_id" property="tenantId" />
        <result column="version" property="version" />
    </resultMap>


    <!-- 真实删除 -->
    <delete id="actualDeleteById">
        DELETE FROM shopflow_message WHERE id = #{id}
    </delete>

    <!-- 批量真实删除 -->
    <delete id="actualDeleteByIds">
        DELETE FROM shopflow_message WHERE id IN (
            SELECT id FROM (
                SELECT DISTINCT id
                FROM shopflow_message
                WHERE id IN
                <foreach item="id" collection="idList" open="(" separator="," close=")">
                    #{id}
                </foreach>
            ) AS tmp
        )
    </delete>


</mapper>
