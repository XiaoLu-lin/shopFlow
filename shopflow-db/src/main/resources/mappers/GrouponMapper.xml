<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.ysling.shopflow.db.mapper.GrouponMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="org.ysling.shopflow.db.domain.ShopflowGroupon">
        <id column="id" property="id" />
        <result column="order_id" property="orderId" />
        <result column="groupon_id" property="grouponId" />
        <result column="rules_id" property="rulesId" />
        <result column="user_id" property="userId" />
        <result column="share_url" property="shareUrl" />
        <result column="creator_user_id" property="creatorUserId" />
        <result column="status" property="status" />
        <result column="add_time" property="addTime" />
        <result column="update_time" property="updateTime" />
        <result column="deleted" property="deleted" />
        <result column="tenant_id" property="tenantId" />
        <result column="version" property="version" />
    </resultMap>


    <!-- 真实删除 -->
    <delete id="actualDeleteById">
        DELETE FROM shopflow_groupon WHERE id = #{id}
    </delete>

    <!-- 批量真实删除 -->
    <delete id="actualDeleteByIds">
        DELETE FROM shopflow_groupon WHERE id IN (
            SELECT id FROM (
                SELECT DISTINCT id
                FROM shopflow_groupon
                WHERE id IN
                <foreach item="id" collection="idList" open="(" separator="," close=")">
                    #{id}
                </foreach>
            ) AS tmp
        )
    </delete>


</mapper>
